generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  employee  Employee?
}

model Employee {
  id                    Int      @id @default(autoincrement())
  profession            String
  email                 String   @unique
  phone                 String?
  hourlyRate            Float?
  userId                String?  @unique
  createdAt             DateTime @default(now())
  contractedHoursPerDay Float?
  employmentType        EmploymentType?
  firstName             String
  lastName              String

  user        User? @relation(fields: [userId], references: [id])
  assignments ServiceAssignment[]
}

model Client {
  id         Int      @id @default(autoincrement())
  clientCode String   @unique
  name       String
  phone      String?
  email      String?
  createdAt  DateTime @default(now())
  address    String?
  category   ClientCategory @default(C)

  services Service[]
}

model Service {
  id             Int      @id @default(autoincrement())
  code           String?
  date           DateTime
  address        String
  status         String
  requiresKey    Boolean  @default(false)
  notes          String?
  clientId       Int
  createdAt      DateTime @default(now())
  actualEndTime  DateTime?
  startTime      DateTime?
  actualStartTime DateTime?
  importantNotes String?
  serviceCodeId  Int?
  duration       Float?
  serviceCode ServiceCode? @relation(fields: [serviceCodeId], references: [id])

  client      Client   @relation(fields: [clientId], references: [id])
  assignments ServiceAssignment[]
}

model ServiceAssignment {
  id         Int      @id @default(autoincrement())
  serviceId  Int
  employeeId Int
  assignedAt DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, employeeId])
}

model ServiceCode {
  id          Int      @id @default(autoincrement())
  code        String
  description String
  createdAt   DateTime @default(now())
  services    Service[]
}

enum Role {
  ADMIN
  ACCOUNTANT
  EMPLOYEE
}

enum EmploymentType {
  HOURLY
  FIXED
}

enum ClientCategory {
  A
  B
  C
  D
  E
  Z
}