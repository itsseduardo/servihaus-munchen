generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  employee  Employee?
}

model Employee {
  id                    Int      @id @default(autoincrement())
  profession            String
  email                 String   @unique
  phone                 String?
  hourlyRate            Float?
  userId                String?  @unique
  createdAt             DateTime @default(now())
  contractedHoursPerWeek Float?
  vacationDaysPerYear   Int?
  active                Boolean         @default(true)
  employmentType        EmploymentType?
  firstName             String
  lastName              String

  auditLogs             AuditLog[]
  timeBlocks            TimeBlock[]

  user        User? @relation(fields: [userId], references: [id])
  assignments ServiceAssignment[]
}

model Client {
  id         Int      @id @default(autoincrement())
  clientCode String   @unique
  name       String
  phone      String?
  email      String?
  createdAt  DateTime @default(now())
  address    String?
  category   ClientCategory @default(C)

  clientType    ClientType     @default(PRIVAT) // PRIVAT o FIRMA

  services Service[]
}

model Service {
  id                Int       @id @default(autoincrement())

  code              String?
  date              DateTime
  address           String
  status            String
  requiresKey       Boolean   @default(false)
  notes             String?
  importantNotes    String?

  clientId          Int
  createdAt         DateTime  @default(now())

  startTime         DateTime?
  actualStartTime   DateTime?
  actualEndTime     DateTime?

  // NUEVO
  billedHours       Float?     // Lo que el cliente paga
  teamDuration      Float?     // Tiempo real que ocupa en calendario
  pricingModel      PricingModel @default(TIME)

  travelTime      Int?        @default(0)   // Tiempo de desplazamiento en minutos
  changeReason    String?                   // Justificación legal de edición manual

  //  Temporal (lo elimino luego)
  duration          Float?

  serviceCodeId     Int?
  serviceCode       ServiceCode? @relation(fields: [serviceCodeId], references: [id])

  client            Client     @relation(fields: [clientId], references: [id])
  assignments       ServiceAssignment[]

  // =========================
  // RECURRENCIA
  // =========================
  recurrenceRule     String?    // DAILY, WEEKLY, BIWEEKLY, MONTHLY
  recurrenceInterval Int?       // cada cuántas unidades (1 = cada semana, 2 = cada 2 semanas)
  recurrenceEnd      DateTime?  // fecha límite
  recurrenceDays     String[] @db.Text
  parentServiceId    Int?

  parentService Service? @relation("Recurrence", fields: [parentServiceId], references: [id])
  childServices Service[] @relation("Recurrence")
}

enum PricingModel {
  TIME
  FIXED
}

model ServiceAssignment {
  id         Int      @id @default(autoincrement())
  serviceId  Int
  employeeId Int
  assignedAt DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, employeeId])
}

model ServiceCode {
  id          Int      @id @default(autoincrement())
  code        String
  description String
  createdAt   DateTime @default(now())
  services    Service[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   // "UPDATE_HOURS", "DELETE_SERVICE", etc.
  entityId    Int      // ID del servicio o empleado afectado
  entityType  String   // "SERVICE" o "EMPLOYEE"
  userId      String   // Quién hizo el cambio (ID de User)
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  reason      String?  @db.Text // El "changeReason" que pedimos en el modal
  createdAt   DateTime @default(now())
  
  employee    Employee? @relation(fields: [employeeId], references: [id])
  employeeId  Int?
}

model TimeBlock {
  id            Int            @id @default(autoincrement())
  employeeId    Int
  date          DateTime
  duration      Float          // Horas a computar
  type          TimeBlockType  // VACATION, SICK, CLIENT_CANCELLED, PAID_LEAVE
  reason        String?        // Nota aclaratoria
  createdAt     DateTime       @default(now())

  employee      Employee       @relation(fields: [employeeId], references: [id])
}

enum TimeBlockType {
  VACATION
  SICK
  CLIENT_CANCELLED
  PAID_LEAVE
}

enum Role {
  ADMIN
  ACCOUNTANT
  EMPLOYEE
}

enum EmploymentType {
  MINIJOB_538 // El límite actual en Alemania
  MIDIJOB
  FULL_TIME
}

enum ClientType {
  PRIVAT
  FIRMA
}

enum ClientCategory {
  A
  B
  C
  D
  E
  Z
}