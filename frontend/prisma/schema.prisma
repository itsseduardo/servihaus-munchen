generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(EMPLOYEE)
  createdAt DateTime  @default(now())
  
  employee  Employee? // Relación actual
  
  // NUEVA RELACIÓN PARA CLIENTES
  client    Client?   @relation(fields: [clientId], references: [id])
  clientId  Int?      @unique 
}

model Employee {
  id                    Int      @id @default(autoincrement())
  profession            String
  email                 String   @unique
  phone                 String?
  hourlyRate            Float?
  userId                String?  @unique
  createdAt             DateTime @default(now())
  contractedHoursPerWeek Float?
  vacationDaysPerYear   Int?
  active                Boolean         @default(true)
  employmentType        EmploymentType?
  firstName             String
  lastName              String

  auditLogs             AuditLog[]
  timeBlocks            TimeBlock[]
  workShifts          WorkShift[]
  payrollRecords PayrollRecord[]
  workAuditLogs          EmployeeAuditLog[] @relation("EmployeeWorkAudits")

  user        User? @relation(fields: [userId], references: [id])
  assignments ServiceAssignment[]
  debtHours Float @default(0) // Horas que el empleado debe recuperar
  isActive  Boolean @default(true)
}

model Client {
  id         Int      @id @default(autoincrement())
  clientCode String   @unique
  name       String
  phone      String?
  email      String?
  createdAt  DateTime @default(now())
  address    String?
  category   ClientCategory @default(C)

  clientType    ClientType     @default(PRIVAT) // PRIVAT o FIRMA
  hasCompletedOnboarding Boolean        @default(false) // Control de onboarding

  services Service[]
  inventories   ClientInventory[]
  deliveryLogs  DeliveryLog[]
  user       User?
}

model Service {
  id                Int       @id @default(autoincrement())

  code              String?
  date              DateTime
  address           String
  status            String
  requiresKey       Boolean   @default(false)
  notes             String?
  importantNotes    String?

  clientId          Int
  createdAt         DateTime  @default(now())

  startTime         DateTime?
  actualStartTime   DateTime?
  actualEndTime     DateTime?

  // NUEVO
  billedHours       Float?     // Lo que el cliente paga
  teamDuration      Float?     // Tiempo real que ocupa en calendario
  pricingModel      PricingModel @default(TIME)

  travelTime      Int?        @default(0)   // Tiempo de desplazamiento en minutos
  changeReason    String?                   // Justificación legal de edición manual

  //  Temporal (lo elimino luego)
  duration          Float?

  serviceCodeId     Int?
  serviceCode       ServiceCode? @relation(fields: [serviceCodeId], references: [id])

  client            Client     @relation(fields: [clientId], references: [id])
  assignments       ServiceAssignment[]

  // =========================
  // RECURRENCIA
  // =========================
  recurrenceRule     String?    // DAILY, WEEKLY, BIWEEKLY, MONTHLY
  recurrenceInterval Int?       // cada cuántas unidades (1 = cada semana, 2 = cada 2 semanas)
  recurrenceEnd      DateTime?  // fecha límite
  recurrenceDays     String[] @db.Text
  parentServiceId    Int?

  parentService Service? @relation("Recurrence", fields: [parentServiceId], references: [id])
  childServices Service[] @relation("Recurrence")

  actualTravelStartTime DateTime?
  extraHoursReason      String?   @db.Text
  overtimeJustification String?   @db.Text
  adminNotes            String?   @db.Text
}

enum PricingModel {
  TIME
  FIXED
}

model ServiceAssignment {
  id         Int      @id @default(autoincrement())
  serviceId  Int
  employeeId Int
  assignedAt DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, employeeId])
}

model ServiceCode {
  id          Int      @id @default(autoincrement())
  code        String
  description String
  createdAt   DateTime @default(now())
  services    Service[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   // "UPDATE_HOURS", "DELETE_SERVICE", etc.
  entityId    Int      // ID del servicio o empleado afectado
  entityType  String   // "SERVICE" o "EMPLOYEE"
  userId      String   // Quién hizo el cambio (ID de User)
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  reason      String?  @db.Text // El "changeReason" que pedimos en el modal
  createdAt   DateTime @default(now())
  
  employee    Employee? @relation(fields: [employeeId], references: [id])
  employeeId  Int?
}

model TimeBlock {
  id            Int            @id @default(autoincrement())
  employeeId    Int
  date          DateTime
  duration      Float          // Horas a computar
  type          TimeBlockType  // VACATION, SICK, CLIENT_CANCELLED, PAID_LEAVE
  reason        String?        // Nota aclaratoria
  createdAt     DateTime       @default(now())

  employee      Employee       @relation(fields: [employeeId], references: [id])
}

// --- NUEVOS MODELOS DE INVENTARIO ---

model Product {
  id          Int               @id @default(autoincrement())
  name        String            @unique // Ej: "Domestos Prof Gel WC"
  unit        String            // Ej: "1L", "200Stk"
  minStock    Float             @default(1) // El límite para que salte la alerta a José
  globalStock Float             @default(0) // Lo que hay en la oficina de Servihaus
  inventories ClientInventory[]
  movements       InventoryMovement[]
}

model InventoryMovement {
  id          Int          @id @default(autoincrement())
  
  // Relación con el producto
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   Int
  
  type        MovementType // Si es IN (Entrada) o OUT (Salida)
  quantity    Float        // Cantidad movida
  
  // Datos financieros (Principalmente para entradas)
  costPerUnit Float?       // Cuánto costó cada unidad (ej. 2.50€ por litro)
  provider    String?      // Quién lo vendió (ej. Metro, Amazon, Aldi)
  
  // Metadatos
  notes       String?      // Notas (ej. "Llegaron 2 botellas rotas")
  createdAt   DateTime     @default(now())
}

model ClientInventory {
  id          Int      @id @default(autoincrement())
  clientId    Int
  productId   Int
  quantity    Float    // Cantidad actual en el cliente
  lastUpdated DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model DeliveryLog {
  id           Int      @id @default(autoincrement())
  deliveryCode String   @unique // Ej: "SAMP.0126.100-A.1"
  clientId     Int
  date         DateTime
  items        Json     // Guardamos el recibo de lo que se entregó
  createdAt    DateTime @default(now())

  client       Client   @relation(fields: [clientId], references: [id])
}

model WorkShift {
  id                    Int            @id @default(autoincrement())
  employeeId            Int
  employee              Employee       @relation(fields: [employeeId], references: [id])
  
  date                  DateTime       @default(now())
  clockIn               DateTime       @default(now())
  clockOut              DateTime?      // Se llena al terminar la jornada
  
  status                ShiftStatus    @default(ON_TIME)
  justification         String?        @db.Text
  approvalStatus        ApprovalStatus @default(PENDING)
  
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

// Modelo para registrar los costos mensuales exactos (El Excel de José)
model PayrollRecord {
  id              Int      @id @default(autoincrement())
  month           Int      // 1 al 12 (Enero a Diciembre)
  year            Int      // Ej. 2024
  
  workedHours     Float    // Horas reales trabajadas ese mes
  
  // La tablita de costos
  brutto          Float    // Salario Bruto
  svAbzuege       Float    // SV-rechtliche Abzüge (Salud, Pensión, Knappschaft)
  steuerAbzuege   Float    // Steuerrechtliche Abzüge (Lohnsteuer, etc.)
  netto           Float    // Salario Neto (Lo que recibe el empleado)
  totalCost       Float    // Costo total para ServiHaus (Lo que sale del bolsillo de José)

  // Relación con el empleado
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Para evitar que se creen dos nóminas del mismo empleado en el mismo mes y año
  @@unique([employeeId, month, year])
}

enum EmployeeAuditType {
  ADJUSTMENT  // Ajuste manual (ej. para saldar deudas)
  ABSENCE     // Falta (no asistió)
  LATE        // Llegada tarde
  OVERTIME    // Horas extra aprobadas
  SICK_LEAVE  // falta por enfermedad
}

model EmployeeAuditLog {
  id          Int               @id @default(autoincrement())
  date        DateTime          @default(now())
  type        EmployeeAuditType
  hours       Float             // Cantidad de horas afectadas (+ o -)
  reason      String            // Justificación
  performedBy String            // Quién hizo el registro (Admin)

  // Relación con el empleado
  employeeId  Int
  employee    Employee          @relation("EmployeeWorkAudits", fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt   DateTime          @default(now())
}

enum TimeBlockType {
  VACATION
  SICK
  CLIENT_CANCELLED
  PAID_LEAVE
}

enum Role {
  ADMIN
  CLIENT
  EMPLOYEE
}

enum EmploymentType {
  MINIJOB_603 // El límite actual en Alemania
  MIDIJOB
  FULL_TIME
}

enum ClientType {
  PRIVAT
  FIRMA
}

enum ClientCategory {
  A
  B
  C
  D
  E
  Z
}

enum MovementType {
  IN   // Entrada (Compras a proveedor)
  OUT  // Salida (Entregas a clientes o mermas)
}

enum ShiftStatus {
  ON_TIME
  LATE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}