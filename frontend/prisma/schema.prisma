datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ACCOUNTANT
  EMPLOYEE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  employee  Employee?
}

model Client {
  id          Int       @id @default(autoincrement())
  clientCode  String    @unique
  name        String
  address     String?
  phone       String?
  email       String?
  services    Service[]
  createdAt   DateTime  @default(now())
}

model Service {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  serviceType    String

  date           DateTime  // lo dejamos por ahora
  time           String     // lo dejamos por ahora
  duration       String?    // lo dejamos por ahora

  startTime      DateTime?  // NUEVO
  actualEndTime  DateTime?  // NUEVO

  address        String
  status         String
  requiresKey    Boolean    @default(false)
  notes          String?

  clientId       Int
  client         Client     @relation(fields: [clientId], references: [id])

  assignments    ServiceAssignment[]

  createdAt      DateTime  @default(now())
}

model Employee {
  id          Int      @id @default(autoincrement())
  name        String
  profession  String
  email       String   @unique
  phone       String?
  hourlyRate  Float?

  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])

  assignments ServiceAssignment[]

  createdAt   DateTime @default(now())
}

model ServiceAssignment {
  id          Int      @id @default(autoincrement())

  serviceId   Int
  employeeId  Int

  service     Service  @relation(fields: [serviceId], references: [id])
  employee    Employee @relation(fields: [employeeId], references: [id])

  workedHours Float?
  notes       String?
  status      String?  // assigned | completed

  createdAt   DateTime @default(now())

  @@unique([serviceId, employeeId])
}